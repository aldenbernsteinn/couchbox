{
  "name": "patatin",
  "version": "1.0.0",
  "description": "Xbox One/Series X style PC dashboard controlled by Xbox controllers",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"vite build --watch\" \"electron .\"",
    "dev:vite": "vite",
    "dev:electron": "electron .",
    "build": "vite build && electron-builder",
    "start": "vite build && electron ."
  },
  "keywords": [
    "xbox",
    "dashboard",
    "gamepad",
    "10-foot-ui",
    "couch-gaming"
  ],
  "author": "Alden Bernstein",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "electron": "^41.1.1",
    "ffmpeg-static": "^5.3.0",
    "jquery": "^4.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron-builder": "^26.8.1",
    "vite": "^8.0.3",
    "vite-plugin-electron": "^0.29.1"
  }
}
